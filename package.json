{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --webpack 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "dev:verbose": "LOG_LEVEL=debug next dev -p 3000 --webpack 2>&1 | tee dev.log",
    "dev:quiet": "LOG_LEVEL=warn next dev -p 3000 --webpack 2>&1 | tee dev.log",
    "logs:tail": "tail -f dev.log",
    "logs:agent": "grep -E '\\[agent\\]|\\[tools\\]' dev.log | tail -100",
    "logs:errors": "grep -E '\\[ERROR\\]' dev.log | tail -50",
    "diagnose": "bash scripts/diagnose.sh",
    "diagnose:verbose": "bash scripts/diagnose.sh --verbose",
    "db:push": "bash scripts/db-init.sh",
    "db:force-push": "rm -f db/custom.db* && prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "dev:win": "powershell -Command \"next dev -p 3000 --webpack 2>&1 | Tee-Object -FilePath dev.log\"",
    "build:win": "next build",
    "start:win": "powershell -Command \"$env:NODE_ENV='production'; bun .next/standalone/server.js 2>&1 | Tee-Object -FilePath server.log\"",
    "logs:tail:win": "powershell -Command \"Get-Content dev.log -Wait -Tail 20\"",
    "logs:agent:win": "powershell -Command \"Select-String -Path dev.log -Pattern '\\[agent\\]|\\[tools\\]' | Select-Object -Last 100\"",
    "logs:errors:win": "powershell -Command \"Select-String -Path dev.log -Pattern '\\[ERROR\\]' | Select-Object -Last 50\"",
    "diagnose:win": "powershell -ExecutionPolicy Bypass -File scripts/diagnose.ps1",
    "diagnose:win:verbose": "powershell -ExecutionPolicy Bypass -File scripts/diagnose.ps1 -Verbose",
    "db:push:win": "powershell -ExecutionPolicy Bypass -File scripts/db-init.ps1",
    "db:force-push:win": "powershell -Command \"Remove-Item -Force db/custom.db*; bunx prisma db push\""
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@ai-sdk/react": "^4.0.2",
    "@pixiv/three-vrm": "^3.5.4",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "ai": "^7.0.2",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "onnxruntime-node": "^1.27.0",
    "pino": "^10.3.1",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.6",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^3.3.1",
    "three": "0.160.0",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.160.0",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
